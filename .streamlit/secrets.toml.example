# Copy to .streamlit/secrets.toml and fill in. The real file is gitignored —
# never commit it.
GROQ_API_KEY = ""
SUPABASE_URL = ""
SUPABASE_SERVICE_KEY = ""
QDRANT_URL = ""
QDRANT_API_KEY = ""

# LangSmith tracing is opt-in: leave these unset in production — traces carry
# full report text and chat (PHI). Set locally only when debugging.
LANGCHAIN_API_KEY = ""
LANGCHAIN_TRACING_V2 = ""
LANGCHAIN_PROJECT = "blood-report-analyser-v2"
